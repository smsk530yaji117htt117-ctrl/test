# Google Fit 同期に必要な環境変数 (Render の Environment に設定する)
# 値は記載しない。実際の値は Render ダッシュボードでのみ管理し、
# リポジトリ・PR・Notion・ログには絶対に出力しないこと。

# --- Google OAuth (Desktop App クライアント) ---
GOOGLE_FIT_CLIENT_ID=
GOOGLE_FIT_CLIENT_SECRET=
GOOGLE_FIT_REFRESH_TOKEN=

# --- Notion ---
NOTION_API_KEY=
NOTION_50_DAILY_DB_ID=

# --- 任意: 50_Daily のプロパティ名を既存スキーマに合わせて上書きする場合 ---
# NOTION_50_DAILY_DATE_PROP=日付
# NOTION_50_DAILY_WEIGHT_PROP=体重
# NOTION_50_DAILY_STEPS_PROP=歩数
# NOTION_50_DAILY_CALORIES_PROP=消費カロリー
